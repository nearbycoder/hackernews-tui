{
  "name": "hackernews-tui",
  "version": "0.1.1",
  "description": "A terminal UI for browsing Hacker News with search, filters, and deep threads.",
  "module": "src/index.tsx",
  "type": "module",
  "private": false,
  "bin": {
    "hackernews-tui": "bin/hackernews-tui"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "readme.png"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "hackernews",
    "hn",
    "tui",
    "terminal",
    "opentui",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nearbycoder/hackernews-tui.git"
  },
  "homepage": "https://github.com/nearbycoder/hackernews-tui#readme",
  "bugs": {
    "url": "https://github.com/nearbycoder/hackernews-tui/issues"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "dev:watch": "bun run --watch src/index.tsx",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "bun run lint && bun run typecheck && bun run test",
    "prepublishOnly": "bun run check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "react": "^19.2.4"
  }
}
